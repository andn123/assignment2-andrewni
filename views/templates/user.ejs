<div class="container mt-4">
  <div class="card p-3" style="max-width: 600px; margin: 0 auto;">
    <div class="d-flex justify-content-between align-items-center">
      <h5 class="mb-0"><%= user.name %></h5>
      <div class="d-flex gap-2">
        <form action="/promote/<%= user._id %>" method="post">
          <button class="btn btn-danger rounded-pill px-3 btn-sm">
            Promote to Admin
          </button>
        </form>
        <form action="/demote/<%= user._id %>" method="post">
          <button class="btn btn-success rounded-pill px-3 btn-sm">
            Demote to User
          </button>
        </form>
      </div>
    </div>
  </div>
</div>